{
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    /*
     * **ATTENTION:**
     * We try to be as runtime environment agnostic as possible. Try to avoid
     * adding any new entries here. Rather declare global dependencies inside the
     * global.d.ts file and communicate them clearly as requirements to users of
     * the library.
     */
    "lib": ["ES2024"],
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "strict": true,
    "noErrorTruncation": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "types": ["vitest/importMeta"],
    "paths": {
      "~/*": ["./src/*"]
    }
  }
}
